rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "nmajufavour16@gmail.com"
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return request.resource.data.uid is string &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin', 'user'];
    }
    
    function isValidSemester() {
      return request.resource.data.userId is string &&
             request.resource.data.name is string &&
             request.resource.data.level is string;
    }
    
    function isValidCourse() {
      return request.resource.data.userId is string &&
             request.resource.data.semesterId is string &&
             request.resource.data.code is string &&
             request.resource.data.units is number;
    }
    
    function isValidChatSession() {
      return request.resource.data.userId is string &&
             request.resource.data.title is string &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string;
    }
    
    function isValidChatMessage() {
      return request.resource.data.chatId is string &&
             request.resource.data.userId is string &&
             request.resource.data.role in ['user', 'assistant'] &&
             request.resource.data.content is string &&
             request.resource.data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /semesters/{semesterId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidSemester();
      allow update: if isAuthenticated() && isDocOwner() && request.resource.data.userId == resource.data.userId && isValidSemester();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidCourse();
      allow update: if isAuthenticated() && isDocOwner() && request.resource.data.userId == resource.data.userId && isValidCourse();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /chat_sessions/{sessionId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidChatSession();
      allow update: if isAuthenticated() && isDocOwner() && request.resource.data.userId == resource.data.userId && isValidChatSession();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /chat_messages/{messageId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidChatMessage();
      allow update: if isAuthenticated() && isDocOwner() && request.resource.data.userId == resource.data.userId && isValidChatMessage();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /metadata/{docId} {
      allow read: if true; // Publicly readable for app initialization
      allow write: if isAdmin();
    }
  }
}
