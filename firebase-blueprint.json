{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "targetCGPA": { "type": "number" },
        "gradingScale": { "type": "number" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string" },
        "institution": { "type": "string" },
        "faculty": { "type": "string" },
        "department": { "type": "string" },
        "level": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Semester": {
      "title": "Semester",
      "description": "A semester",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "name"]
    },
    "Course": {
      "title": "Course",
      "description": "A course",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "semesterId": { "type": "string" },
        "code": { "type": "string" },
        "title": { "type": "string" },
        "units": { "type": "number" },
        "grade": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "semesterId", "code", "units"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "title"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isThinking": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["chatId", "userId", "role", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/semesters/{semesterId}": {
      "schema": { "$ref": "Semester" },
      "description": "Semesters"
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "Course" },
      "description": "Courses"
    },
    "/chatSessions/{sessionId}": {
      "schema": { "$ref": "ChatSession" },
      "description": "Chat sessions"
    },
    "/chatMessages/{messageId}": {
      "schema": { "$ref": "ChatMessage" },
      "description": "Chat messages"
    }
  }
}
