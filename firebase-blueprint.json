{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "targetCGPA": { "type": "number" },
        "gradingScale": { "type": "number" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string" },
        "institution": { "type": "string" },
        "faculty": { "type": "string" },
        "department": { "type": "string" },
        "level": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Semester": {
      "title": "Semester",
      "description": "A semester",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "name"]
    },
    "Course": {
      "title": "Course",
      "description": "A course",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "semesterId": { "type": "string" },
        "code": { "type": "string" },
        "title": { "type": "string" },
        "units": { "type": "number" },
        "grade": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "semesterId", "code", "units"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "title"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isThinking": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["chatId", "userId", "role", "content"]
    },
    "CourseReview": {
      "title": "CourseReview",
      "description": "Student review for a course",
      "type": "object",
      "properties": {
        "courseCode": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "difficulty": { "type": "number" },
        "comment": { "type": "string" },
        "tips": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["courseCode", "userId", "rating", "comment", "createdAt"]
    },
    "CourseMaterial": {
      "title": "CourseMaterial",
      "description": "Shared study material for a course",
      "type": "object",
      "properties": {
        "courseCode": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Note", "Past Question", "Textbook", "Video", "Link"] },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["courseCode", "userId", "title", "type", "url", "createdAt"]
    },
    "CommunityCourse": {
      "title": "CommunityCourse",
      "description": "A course added by the community",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "title": { "type": "string" },
        "units": { "type": "number" },
        "department": { "type": "string" },
        "institution": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["code", "title", "units", "addedBy", "createdAt"]
    },
    "AppMetadata": {
      "title": "AppMetadata",
      "description": "Global application metadata",
      "type": "object",
      "properties": {
        "institutions": { "type": "array", "items": { "type": "string" } },
        "faculties": { "type": "array", "items": { "type": "string" } },
        "departments": { "type": "array", "items": { "type": "string" } },
        "courseTemplates": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "title": { "type": "string" },
              "units": { "type": "number" }
            }
          } 
        }
      }
    }
  },
  "firestore": {
    "/metadata/{configId}": {
      "schema": { "$ref": "AppMetadata" },
      "description": "Global application configuration"
    },
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/semesters/{semesterId}": {
      "schema": { "$ref": "Semester" },
      "description": "Semesters"
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "Course" },
      "description": "Courses"
    },
    "/chatSessions/{sessionId}": {
      "schema": { "$ref": "ChatSession" },
      "description": "Chat sessions"
    },
    "/chatMessages/{messageId}": {
      "schema": { "$ref": "ChatMessage" },
      "description": "Chat messages"
    },
    "/courseReviews/{reviewId}": {
      "schema": { "$ref": "CourseReview" },
      "description": "Course reviews"
    },
    "/courseMaterials/{materialId}": {
      "schema": { "$ref": "CourseMaterial" },
      "description": "Course materials"
    },
    "/communityCourses/{courseId}": {
      "schema": { "$ref": "CommunityCourse" },
      "description": "Community courses"
    }
  }
}
